# Data and generated artifacts
data/raw/*
data/interim/*
data/processed/*
data/splits/*
checkpoints/*
results/*
reports/figures/*
reports/tables/*
reports/final_results/*

# Preserve directory documentation/placeholders
!data/**/README.md
!data/splits/.gitkeep
!checkpoints/.gitkeep
!results/.gitkeep
!reports/figures/.gitkeep
!reports/tables/.gitkeep
!reports/tables/data_audit_summary.json
!reports/tables/shortcut_baselines.json
!reports/tables/sensitivity_selection.json
!reports/final_results/*.csv
!reports/final_results/*.json
!reports/final_results/*.png

# Python
.venv/
.tools/
.python/
.cache/
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/

# Notebooks and editors
.ipynb_checkpoints/
.vscode/
.idea/

# Local configuration and secrets
.env
*.local.yaml

# OS files
.DS_Store
Thumbs.db
